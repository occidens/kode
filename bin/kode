#!/usr/bin/env bash

SOCK=/tmp/code-trigger.sock

kode_open () {
# realpath so the local side gets an absolute path that exists on the server
printf '%s\n%s\n' "$(hostname -s)" "$(realpath "${1:-$PWD}")" \
  | socat - UNIX-CONNECT:${SOCK}
}

kode_listen () {
    exec socat \
        UNIX-LISTEN:${SOCK},fork,reuseaddr \
        EXEC:"$0 handle"
}

kode_handle () {
    IFS= read -r host
    IFS= read -r path
    exec code --remote "ssh-remote+${host}" "$path"
}

main () {
    local cmd="$1"

    case "$cmd" in
        open)
            kode_open "$@"
            ;;
        listen)
            kode_listen "$@"
            ;;
        handle)
            kode_handle "$@"
            ;;
        *)
            echo "usage: $0 {listen|open}"
            exit 1
        ;;
    esac
}

main "$@"
