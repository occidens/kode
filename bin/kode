#!/usr/bin/env bash

kode_open () {
# realpath so the local side gets an absolute path that exists on the server
printf '%s\n' "$(realpath "${1:-$PWD}")" \
    | socat - UNIX-CONNECT:/tmp/code-trigger.sock
}

kode_listen () {
    exec socat \
        UNIX-LISTEN:/tmp/code-trigger.sock,fork,reuseaddr \
        SYSTEM:'read p; code --remote ssh-remote+saarinen "$p"'
}

main () {
    local cmd="$1"

    case "$cmd" in
        open)
            kode_open
        ;;
        listen)
            kode_listen
        ;;
        *)
        echo "usage: $0 {listen|open}"
        exit 1
        ;;
    esac
}

main "$@"
